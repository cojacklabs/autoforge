{
  "name": "autoforge",
  "version": "1.1.0",
  "type": "module",
  "private": false,
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yaml,yml}\"",
    "validate": "node ./scripts/validate_context.js",
    "repomix": "node ./scripts/generate_repomix.js",
    "update": "node ./scripts/update_autoforge.js",
    "build": "node ./scripts/build_dist.js",
    "prepack": "npm run build"
  },
  "bin": {
    "autoforge": "./bin/autoforge.js"
  },
  "files": [
    "dist",
    "bin/autoforge.js"
  ],
  "devDependencies": {
    "ignore": "^5.3.1",
    "prettier": "^3.3.3",
    "repomix": "^1.1.0",
    "yaml": "^2.4.2",
    "glob": "^10.3.0"
  }
}
